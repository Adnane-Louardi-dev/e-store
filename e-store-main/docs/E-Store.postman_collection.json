{
  "info": {
    "name": "E-Store Backend",
    "description": "End-to-end collection for the E-Store Spring Boot backend (Days 1-8). Run requests from top to bottom: Login captures the JWT into the {{token}} variable; subsequent requests use it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "cartItemId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"new@estore.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (seeded user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@estore.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (seeded admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@estore.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('adminToken', pm.response.json().token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/users/me/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+212600000000\",\n  \"address\": \"Bd Anfa\",\n  \"city\": \"Casablanca\",\n  \"country\": \"Morocco\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" }
        },
        {
          "name": "Create category (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toys\",\n  \"description\": \"Playthings\"\n}"
            }
          }
        },
        {
          "name": "Search products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?q=&categoryId=&page=0&size=20&sort=id,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "q", "value": "" },
                { "key": "categoryId", "value": "" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "id,desc" }
              ]
            }
          }
        },
        {
          "name": "Get product",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/{{productId}}" }
        },
        {
          "name": "Create product (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"Description\",\n  \"price\": 19.99,\n  \"imageUrl\": \"https://placehold.co/600x400\",\n  \"categoryId\": {{categoryId}}\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get stock",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/inventory/product/{{productId}}"
          }
        },
        {
          "name": "Set stock (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/inventory/product/{{productId}}",
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 50\n}" }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Add item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/cart/items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 && pm.response.json().items.length) {",
                  "  pm.collectionVariables.set('cartItemId', pm.response.json().items[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/cart/items/{{cartItemId}}",
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" }
          }
        },
        {
          "name": "Remove item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "Clear cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cart"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('orderId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "My orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders/user/me?page=0&size=20&sort=orderDate,desc"
          }
        },
        {
          "name": "Get order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Post review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"rating\": 5,\n  \"comment\": \"Excellent product\"\n}"
            }
          }
        },
        {
          "name": "Reviews for product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reviews/product/{{productId}}?page=0&size=20&sort=createdAt,desc"
          }
        }
      ]
    }
  ]
}
